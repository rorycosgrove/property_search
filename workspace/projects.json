      "type": "package",
      "language": "python",
      "tags": ["layer:domain", "domain:sources"],
      "dependsOn": ["shared", "storage", "normalizer"],
      "commands": {
        "lint": "uv run ruff check packages/sources",
        "build": "python -m compileall packages/sources"
      }
    },
    {
      "id": "normalizer",
      "path": "packages/normalizer",
      "type": "package",
      "language": "python",
      "tags": ["layer:domain", "domain:normalizer"],
