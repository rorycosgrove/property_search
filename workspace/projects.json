      "commands": {
        "lint": "uv run ruff check apps/worker",
        "build": "python -m compileall apps/worker"
      }
    },
    {
      "id": "web",
      "path": "web",
      "type": "frontend",
      "language": "typescript",
      "tags": ["layer:app", "domain:web"],
      "dependsOn": ["shared"],
      "commands": {
        "lint": "npm --prefix web run lint",
        "build": "npm --prefix web run build"
      }
    },
    {
      "id": "shared",
      "path": "packages/shared",
      "type": "package",
      "language": "python",
      "tags": ["layer:foundation", "domain:shared"],
      "dependsOn": [],
