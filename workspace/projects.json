{
  "version": 1,
  "projects": [
    {
      "id": "api",
      "path": "apps/api",
      "type": "service",
      "language": "python",
      "tags": ["layer:app", "domain:api"],
      "dependsOn": ["shared", "storage", "sources", "normalizer", "alerts", "analytics", "ai"],
      "commands": {
        "lint": "uv run ruff check apps/api",
        "build": "python -m compileall apps/api"
      }
    },
    {
      "id": "worker",
      "path": "apps/worker",
      "type": "service",
      "language": "python",
      "tags": ["layer:app", "domain:worker"],
