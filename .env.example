# ── Database ──────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=propertysearch
POSTGRES_USER=propertysearch
POSTGRES_PASSWORD=changeme_in_production

# ── Redis ─────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ── Celery ────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── API ───────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
LOG_LEVEL=INFO

# ── Frontend ──────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── LLM (Provider-Agnostic) ──────────────────
LLM_PROVIDER=ollama
LLM_ENABLED=false

# Ollama settings
OLLAMA_ENDPOINT=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT_SECONDS=120

# OpenAI settings (also works for Claude via compatible API)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_ENDPOINT=https://api.openai.com/v1
OPENAI_TIMEOUT_SECONDS=60

# ── Scraping ──────────────────────────────────
SCRAPE_POLL_INTERVAL_SECONDS=900
RSS_POLL_INTERVAL_SECONDS=300
PPR_POLL_INTERVAL_SECONDS=604800
MAX_SCRAPE_RETRIES=3
REQUEST_TIMEOUT_SECONDS=30
SCRAPE_DELAY_MIN_SECONDS=2
SCRAPE_DELAY_MAX_SECONDS=5
USER_AGENT=PropertySearch/1.0 (+https://github.com/property-search)

# ── Geocoding ─────────────────────────────────
GEOCODER_PROVIDER=nominatim
GEOCODER_USER_AGENT=PropertySearch/1.0
GEOCODER_RATE_LIMIT=1

# ── Observability ─────────────────────────────
ENABLE_METRICS=true
ENABLE_TRACING=false
