# ── Database ──────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=propertysearch
POSTGRES_USER=propertysearch
POSTGRES_PASSWORD=changeme_in_production

# ── AWS ───────────────────────────────────────
AWS_REGION=eu-west-1
# AWS_SECRETS_ARN=             # Set by CDK in Lambda
# SCRAPE_QUEUE_URL=            # Set by CDK in Lambda
# LLM_QUEUE_URL=               # Set by CDK in Lambda
# ALERT_QUEUE_URL=             # Set by CDK in Lambda
# DYNAMODB_CONFIG_TABLE=       # Set by CDK in Lambda

# ── API ───────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
LOG_LEVEL=INFO

# ── Frontend ──────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── LLM (Amazon Bedrock) ─────────────────────
LLM_PROVIDER=bedrock
LLM_ENABLED=false
BEDROCK_MODEL_ID=amazon.titan-text-express-v1
BEDROCK_MAX_TOKENS=4096

# ── Scraping ──────────────────────────────────
SCRAPE_POLL_INTERVAL_SECONDS=900
RSS_POLL_INTERVAL_SECONDS=300
PPR_POLL_INTERVAL_SECONDS=604800
MAX_SCRAPE_RETRIES=3
REQUEST_TIMEOUT_SECONDS=30
SCRAPE_DELAY_MIN_SECONDS=2
SCRAPE_DELAY_MAX_SECONDS=5
USER_AGENT=PropertySearch/1.0 (+https://github.com/property-search)

# ── Geocoding ─────────────────────────────────
GEOCODER_PROVIDER=nominatim
GEOCODER_USER_AGENT=PropertySearch/1.0
GEOCODER_RATE_LIMIT=1

# ── Observability ─────────────────────────────
ENABLE_METRICS=true
ENABLE_TRACING=false
BACKEND_LOG_RETENTION_DAYS=7
